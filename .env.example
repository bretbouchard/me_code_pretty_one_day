# me_code_pretty_one_day — Environment Variables
# Copy to .env and fill in as needed.
# All variables are OPTIONAL — the pipeline works without any of them.

# GitHub token for scrape_corpus.py (optional — works without auth
# but may hit rate limits with unauthenticated GitHub API requests)
GITHUB_TOKEN=

# Ollama host (default: localhost:11434)
# OLLAMA_HOST=localhost:11434
