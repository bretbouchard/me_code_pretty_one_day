# Model weights (large binary files, download via scripts)
models/

# Training artifacts (large binary files, generated by training)
training/adapters/
training/adapters-*/
training/fused_model/

# Training data (generated, reproducible from seed examples)
data/train.jsonl
data/valid.jsonl

# Generated corpus (from scrape_local.py)
data/corpus-local/
data/local_pairs.jsonl

# Duplicate formatting files (canonical copies live in data/formatting/)
data/formatting_train.jsonl
data/formatting_val.jsonl
data/formatting_test_prompts.jsonl

# Python
__pycache__/
*.pyc
*.egg-info/

# OS
.DS_Store

# Environment
.env

# IDE
.idea/
.vscode/
*.swp

# Training logs
training/*.log

# Benchmark cache
.benchmarks/
.pytest_cache/

# Worktrees
.claude/worktrees/

# Internal tooling (not part of starter template)
.planning/
.claude/
CLAUDE.md
